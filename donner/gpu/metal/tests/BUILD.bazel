load("//build_defs:rules.bzl", "donner_cc_binary", "donner_cc_library", "donner_cc_test")

# Tests and tooling for the design 0053 Metal vertical slice: the shared
# frozen-baseline scene, the geode-gated black-box capture tool that produced
# the committed baseline PNG, and the Metal solid-fill pixel-comparison test.

# Black-box baseline capture (design 0053 phase 3): renders the shared scene
# through the current production renderer and writes the PNG committed under
# testdata/. Geode-gated (works on any platform with a WebGPU-capable device,
# not just macOS); see testdata/README.md for the capture command.
donner_cc_binary(
    name = "baseline_capture_tool",
    testonly = 1,
    srcs = ["BaselineCaptureTool.cc"],
    target_compatible_with = select({
        "//donner/svg/renderer/geode:geode_enabled": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    deps = [
        "//donner/gpu:baseline_scene",
        "//donner/svg/renderer:renderer_image_io",
        "//donner/svg/renderer/geode:geo_encoder",
        "//donner/svg/renderer/geode:geode_device",
        "//donner/svg/renderer/geode:geode_wgpu_util",
        "//third_party/webgpu-cpp:webgpu_cpp",
    ],
)

# The Metal solid-fill vertical slice: donner::gpu + emitted MSL only (no
# wgpu-based dependencies, not geode-gated). Metal API validation is enabled
# so validation issues abort loudly.
donner_cc_test(
    name = "metal_solid_fill_tests",
    srcs = ["MetalSolidFill_tests.cc"],
    data = ["testdata/solid_fill_baseline.png"],
    env = {
        "MTL_DEBUG_LAYER": "1",
        "MTL_SHADER_VALIDATION": "1",
    },
    target_compatible_with = ["@platforms//os:macos"],
    deps = [
        "//donner/editor/tests:bitmap_golden_compare",
        "//donner/gpu",
        "//donner/gpu:baseline_scene",
        "//donner/gpu/metal:metal_device",
        "//donner/gpu/shader",
        "//donner/gpu/shader:programs",
        "//donner/svg/renderer/geode:geode_path_encoder",
        "@com_google_gtest//:gtest_main",
    ],
)
