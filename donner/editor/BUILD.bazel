"""Donner Editor: in-tree migration of the external `donner-editor` prototype.

This package is the destination for the editor migration described in
`docs/design_docs/0020-editor.md`. Milestone 1 landed the package skeleton,
build-system foundation, and dependency wiring;
subsequent milestones add
the actual editor source.

The editor builds as part of default `bazel test //...` on supported hosts —
there is no `--config=editor` feature flag. Heavy dependencies (imgui, glfw,
tracy, emsdk, pixelmatch-cpp17) are kept out of BCR consumer dependency
graphs via `dev_dependency = True` in `MODULE.bazel`.
"""

load("@bazel_skylib//lib:selects.bzl", "selects")
load("//build_defs:embed_resources.bzl", "embed_resources")
load("//build_defs:rules.bzl", "donner_cc_binary", "donner_cc_library", "donner_multi_transitioned_binary")

#Editor libraries are public so the  // examples:svg_viewer target (in the
#separate examples Bazel module) can depend on `: text_editor`.BCR
#consumers cannot transitively use the editor libraries because
#imgui / glfw / tracy are `dev_dependency = True` in MODULE.bazel and won't
#resolve outside dev builds.
package(default_visibility = ["//visibility:public"])

config_setting(
    name = "wasm_geode_enabled",
    flag_values = {
        "//donner/editor/wasm:enable_wasm": "true",
        "//donner/svg/renderer:renderer_backend": "geode",
    },
)

config_setting(
    name = "wasm_tiny_skia_enabled",
    flag_values = {
        "//donner/editor/wasm:enable_wasm": "true",
        "//donner/svg/renderer:renderer_backend": "tiny_skia",
    },
)

config_setting(
    name = "linux_tracy_enabled",
    constraint_values = ["@platforms//os:linux"],
    flag_values = {
        "//build_defs:enable_tracy": "true",
    },
)

config_setting(
    name = "macos_tracy_enabled",
    constraint_values = ["@platforms//os:macos"],
    flag_values = {
        "//build_defs:enable_tracy": "true",
    },
)

exports_files(
    ["main.cc"],
    visibility = ["//donner/editor/wasm:__pkg__"],
)

