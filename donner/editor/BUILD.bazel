#The full Donner editor implementation.The public `: editor` target below
#applies the Geode transition so `bazel run  // donner/editor` uses the same
#backend that editor performance work targets without requiring `--config = geode`.
donner_cc_binary(
    name = "editor_impl",
    srcs = ["main.cc"],
    tags = ["manual"],
    target_compatible_with = select({
        "@platforms//os:macos": [],
        "@platforms//os:linux": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    visibility = ["//visibility:private"],
    deps = [
        ":editor_shell",
        ":editor_splash",
        ":notice",
        ":tracy_wrapper",
        "//donner/base",
        "//donner/base:failure_signal_handler",
        "//donner/editor/gui:editor_window",
    ],
)

test_suite(
    name = "editor_lint",
    tests = [":editor_impl_lint"],
)

#The full Donner editor binary.Wires EditorApp + SelectTool +
#OverlayRenderer + TextEditor into an ImGui shell with a live source
#pane and a click - and-drag render pane.The minimal viewer demo lives
#at `  //examples:svg_viewer`.
#
#bazel run  // donner/editor -- donner_splash.svg
donner_multi_transitioned_binary(
    name = "editor",
    dep = ":editor_impl",
    renderer_backend = "geode",
    target_compatible_with = select({
        "@platforms//os:macos": [],
        "@platforms//os:linux": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    text = "true",
    text_full = "false",
)

