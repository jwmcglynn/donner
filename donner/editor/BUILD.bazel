# Conditional Tracy profiling macros. When `ENABLE_TRACY` is defined, the
# library pulls in the real Tracy client; otherwise the macros are no-ops.
# Native editor builds enable Tracy by default and may disable it with
# `--//build_defs:enable_tracy=false`; WASM and RE builds use the no-op wrapper.
donner_cc_library(
    name = "tracy_wrapper",
    hdrs = ["TracyWrapper.h"],
    defines = selects.with_or({
        (":linux_tracy_enabled", ":macos_tracy_enabled"): ["ENABLE_TRACY"],
        "//conditions:default": [],
    }),
    deps = selects.with_or({
        (":linux_tracy_enabled", ":macos_tracy_enabled"): [
            "@tracy//:tracy_client",
        ],
        "//conditions:default": [],
    }),
)

