# Regression test for the "filter element disappears after follow-up
# drag" bug. Replays the user-captured `.donner-repro` against the
# full editor stack and asserts the first-dragged element's
# post-drag-1 region still has visible content in the final bitmap.
donner_cc_test(
    name = "filter_disappear_replay_tests",
    srcs = ["FilterDisappearReplay_tests.cc"],
    size = "large",
    data = [
        ":filter_elm_disappear.rnr",
        ":filter_elm_disappear_minimal.rnr",
        "//:donner_splash.svg",
    ],
    deps = [
        ":repro_replay_harness",
        "//donner/base",
        "//donner/editor/backend_lib:async_renderer",
        "//donner/svg/renderer:renderer_image_io",
        "//donner/svg/renderer:renderer_interface",
        "@com_google_gtest//:gtest_main",
    ],
)

# Golden-image regression test for composited drag promotion. Replays
# `selection_composited_promote_test.rnr` with composited drag preview
# enabled and diffs bitmaps at three pipeline phases against committed
# PNGs. See `CompositedPromoteReplay_tests.cc` for the update workflow.
donner_cc_test(
    name = "composited_promote_replay_tests",
    srcs = ["CompositedPromoteReplay_tests.cc"],
    size = "large",
    data = [
        ":selection_composited_promote_test.rnr",
        ":selection_composited_promote_test_minimal.rnr",
        "//:donner_splash.svg",
    ] + glob(
        ["testdata/composited_promote_*.png"],
        allow_empty = True,
    ),
    deps = [
        ":bitmap_golden_compare",
        ":repro_replay_harness",
        "//donner/editor/backend_lib:async_renderer",
        "//donner/svg/renderer:renderer_image_io",
        "@com_google_gtest//:gtest_main",
    ],
)
