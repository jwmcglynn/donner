# Shared replay harness for tests that drive `EditorApp` + `SelectTool`
# + `RenderCoordinator` from a v2 `.donner-repro` recording. Scoped to
# these tests; collapses into the general `ReproPlayer` when
# `docs/design_docs/0029-ui_input_repro.md` Stage 2 lands.
donner_cc_library(
    name = "repro_replay_harness",
    testonly = 1,
    srcs = ["ReproReplayHarness.cc"],
    hdrs = ["ReproReplayHarness.h"],
    deps = [
        "//donner/base",
        "//donner/editor:render_coordinator",
        "//donner/editor:selection_aabb",
        "//donner/editor:viewport_state",
        "//donner/editor/backend_lib:async_renderer",
        "//donner/editor/backend_lib:editor_app",
        "//donner/editor/backend_lib:select_tool",
        "//donner/editor/repro:repro_file",
        "//donner/svg",
        "//donner/svg/compositor",
        "//donner/svg/renderer",
        "@com_google_gtest//:gtest",
    ],
)

# Golden-PNG comparison helper for editor replay tests. Mirrors the
