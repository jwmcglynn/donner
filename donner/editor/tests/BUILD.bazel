# Golden-PNG comparison helper for editor tests. Mirrors the
# renderer suite's `ImageComparisonTestFixture` diff semantics
# (pixelmatch threshold / max-mismatched-pixels) + update workflow
# (`UPDATE_GOLDEN_IMAGES_DIR=$(bazel info workspace)`).
donner_cc_library(
    name = "bitmap_golden_compare",
    testonly = 1,
    srcs = ["BitmapGoldenCompare.cc"],
    hdrs = ["BitmapGoldenCompare.h"],
    visibility = [
        "//donner/editor/sandbox/tests:__pkg__",
        "//donner/editor/tests:__pkg__",
    ],
    deps = [
        "//donner/svg/renderer:renderer_image_io",
        "//donner/svg/renderer:renderer_interface",
        "//donner/svg/renderer/tests:renderer_image_test_utils",
        "@com_google_gtest//:gtest",
        "@pixelmatch-cpp17",
    ],
)

