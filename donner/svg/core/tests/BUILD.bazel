load("//build_defs:rules.bzl", "donner_cc_library", "donner_cc_test")

donner_cc_library(
    name = "core_test_utils",
    testonly = 1,
    hdrs = [
        "PathTestUtils.h",
    ],
    visibility = ["//donner/svg:__subpackages__"],
    deps = [
        "//donner/base",
        "//donner/svg/core",
        "@com_google_gtest//:gtest",
    ],
)

donner_cc_test(
    name = "core_tests",
    shard_count = 4,
    srcs = [
        "ClipPathUnits_tests.cc",
        "ClipRule_tests.cc",
        "CursorType_tests.cc",
        "Display_tests.cc",
        "DominantBaseline_tests.cc",
        "Event_tests.cc",
        "FillRule_tests.cc",
        "Isolation_tests.cc",
        "LengthAdjust_tests.cc",
        "MarkerOrient_tests.cc",
        "MarkerUnits_tests.cc",
        "MaskUnits_tests.cc",
        "MixBlendMode_tests.cc",
        "Overflow_tests.cc",
        "Path_tests.cc",
        "PointerEvents_tests.cc",
        "PreserveAspectRatio_tests.cc",
        "Stroke_tests.cc",
        "TextAnchor_tests.cc",
        "TextDecoration_tests.cc",
        "TransformOrigin_tests.cc",
        "Visibility_tests.cc",
        "WritingMode_tests.cc",
    ],
    deps = [
        ":core_test_utils",
        "//donner/base:base_test_utils",
        "//donner/svg/core",
        "@com_google_gtest//:gtest_main",
    ],
)
