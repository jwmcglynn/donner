load(
    "//build_defs:rules.bzl",
    "donner_cc_library",
    "donner_cc_test",
    "donner_transitioned_cc_test",
)

donner_cc_test(
    name = "svg_document_concurrency_tests",
    srcs = [
        "SVGDocumentConcurrency_tests.cc",
    ],
    deps = [
        "//donner/svg",
        "@com_google_gtest//:gtest_main",
    ],
)

donner_cc_test(
    name = "svg_element_lifetime_tests",
    srcs = [
        "SVGElementLifetime_tests.cc",
    ],
    deps = [
        "//donner/svg",
        "//donner/svg/graph",
        "//donner/svg/parser",
        "@com_google_gtest//:gtest_main",
    ],
)

donner_cc_test(
    name = "svg_tree_mutation_tests",
    srcs = [
        "SVGTreeMutation_tests.cc",
    ],
    deps = [
        "//donner/svg",
        "@com_google_gtest//:gtest_main",
    ],
)

donner_cc_test(
    name = "svg_tests",
    size = "small",
    srcs = [
        "DonnerController_tests.cc",
        "ElementStyle_tests.cc",
        "ElementType_tests.cc",
        "SVGAElement_tests.cc",
        "SVGCircleElement_tests.cc",
        "SVGClipPathElement_tests.cc",
        "SVGDefsElement_tests.cc",
        "SVGDescElement_tests.cc",
        "SVGDocument_tests.cc",
        "SVGElementPublicApi_tests.cc",
        "SVGElement_tests.cc",
        "SVGEllipseElement_tests.cc",
        "SVGFilterElement_tests.cc",
        "SVGFilterPrimitiveWrapper_tests.cc",
        "SVGImageElement_tests.cc",
        "SVGInvalidation_tests.cc",
        "SVGLineElement_tests.cc",
        "SVGLinearGradientElement_tests.cc",
        "SVGMarkerElement_tests.cc",
        "SVGMaskElement_tests.cc",
        "SVGMetadataElement_tests.cc",
        "SVGPathElement_tests.cc",
        "SVGPatternElement_tests.cc",
        "SVGPolygonPolylineElement_tests.cc",
        "SVGRadialGradientElement_tests.cc",
        "SVGRectElement_tests.cc",
        "SVGSVGElement_tests.cc",
        "SVGStopElement_tests.cc",
        "SVGStyleCascade_tests.cc",
        "SVGStyleElement_tests.cc",
        "SVGSwitchElement_tests.cc",
        "SVGSymbolElement_tests.cc",
        "SVGTSpanElement_tests.cc",
        "SVGTextElement_tests.cc",
        "SVGTextPathElement_tests.cc",
        "SVGTitleElement_tests.cc",
        "SVGUnknownElement_tests.cc",
        "SVGUseElement_tests.cc",
    ],
    shard_count = 10,
    # Variant lanes (doc 0031 M2.3): emits `svg_tests_tiny`,
    # `svg_tests_text_full`, and `svg_tests_geode` so `bazel test //...`
    # exercises every renderer/text tier on every push.
    variants = [
        "tiny",
        "text_full",
        "geode",
    ],
    deps = [
        ":parser_test_utils",
        "//donner/base:base_test_utils",
        "//donner/svg",
        "//donner/svg/core/tests:core_test_utils",
        "//donner/svg/renderer/tests:renderer_test_utils",
        "@com_google_gtest//:gtest_main",
    ],
)

donner_cc_library(
    name = "render_tree_test_utils",
    testonly = 1,
    hdrs = [
        "RenderTreeTestUtils.h",
    ],
    visibility = ["//donner:__subpackages__"],
    deps = [
        "//donner/base",
        "//donner/svg",
    ],
)

donner_cc_library(
    name = "parser_test_utils",
    testonly = 1,
    srcs = [
        "ParserTestUtils.cc",
    ],
    hdrs = [
        "ParserTestUtils.h",
    ],
    visibility = ["//donner:__subpackages__"],
    deps = [
        "//donner/svg",
        "//donner/svg/parser",
        "@com_google_gtest//:gtest",
    ],
)
