donner_cc_library(
    name = "text_shaper",
    srcs = ["TextShaper.cc"],
    hdrs = ["TextShaper.h"],
    visibility = ["//donner/svg:__subpackages__"],
    deps = [
        ":renderer_interface",
        "//donner/svg/resources:font_manager",
        "@freetype//:freetype",
        "@harfbuzz",
    ],
