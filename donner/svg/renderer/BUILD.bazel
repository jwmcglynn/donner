    deps = [
        ":renderer_driver",
        ":renderer_image_io",
        ":renderer_interface",
        ":renderer_utils",
        "//donner/svg",
        "//donner/svg/components",
        "//donner/svg/resources:font_manager",
        "//donner/svg/text:text_engine",
    ] + select({
        ":renderer_backend_geode": [":renderer_geode"],
        "//conditions:default": [":renderer_tiny_skia"],
    }),
)

# Dependency audit: the geode *production* renderer must never link the
# tiny-skia backend. We dropped the `target_compatible_with` guards from the
# pure-CPU tiny-skia libs so the geode *test* binary can embed both backends
# for in-process geode-vs-tiny-skia parity (see
# docs/design_docs/0017-geode_renderer.md §Phase 4b). With those analysis-time
# guards gone, this query-based test is what keeps the line honest: it asserts
# `somepath(:renderer_geode, :renderer_tiny_skia)` is empty, so production geode
# (which routes through :renderer_geode) carries zero tiny-skia code.
#
# How it catches a regression: if anyone adds :renderer_tiny_skia (or anything
# that transitively reaches it) to :renderer_geode's deps — even behind a
# select — the unconfigured `somepath` query finds the path and the test fails,
# printing the offending dependency chain. The test anchors on :renderer_geode,
# NOT the :renderer dispatcher, because :renderer legitimately reaches tiny-skia
# through its `//conditions:default` select branch (which the loading-phase
# graph always includes).
forbidden_transitive_dep_test(
    name = "geode_excludes_tiny_skia_audit",
    forbidden = "//donner/svg/renderer:renderer_tiny_skia",
    tags = [
        "audit",
        "deps",
    ],
    target = "//donner/svg/renderer:renderer_geode",
)
