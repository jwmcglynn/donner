# Shared backend-agnostic text geometry (placement) consumed by both
# RendererTinySkia::drawText and RendererGeode::drawText — the start of the
# 0038 hoist that de-duplicates per-glyph placement so the two backends can't
# drift. Text-only (depends on TextEngine); both backends dep it conditionally
# on `:text_enabled`.
donner_perf_sensitive_cc_library(
    name = "placed_text_geometry",
    srcs = ["PlacedTextGeometry.cc"],
    hdrs = ["PlacedTextGeometry.h"],
    visibility = ["//visibility:public"],
    deps = [
        "//donner/base",
        "//donner/svg/components/text:components",
        "//donner/svg/text:text_engine",
        "//donner/svg/text:text_types",
    ],
    alwayslink = True,  # link-order independence (#665)
)

donner_perf_sensitive_cc_library(
    name = "filter_graph_executor",
    srcs = ["FilterGraphExecutor.cc"],
    hdrs = ["FilterGraphExecutor.h"],
    # Backend-agnostic pure-CPU code: no `target_compatible_with` so it builds
    # under every config (tiny_skia, geode, and the feature-flag variants). The
    # geode test binary links the tiny-skia backend (which pulls this in) for
    # in-process geode-vs-tiny-skia parity. Production geode never reaches this
    # target — enforced by //donner/svg/renderer:geode_excludes_tiny_skia_audit.
    visibility = ["//donner/svg/renderer:__subpackages__"],
    deps = [
        ":pixel_format_utils",
        ":tiny_skia_deps",
        ":tiny_skia_filter_deps",
        "//donner/base",
        "//donner/svg",
    ],
    alwayslink = True,  # link-order independence (#665)
)

