load("@bazel_skylib//rules:common_settings.bzl", "bool_flag", "string_flag")
load("@donner_config//:config.bzl", "DONNER_CONFIG")
load("//build_defs:dep_audit.bzl", "forbidden_transitive_dep_test")
load("//build_defs:rules.bzl", "donner_cc_binary", "donner_cc_library", "donner_perf_sensitive_cc_library")

# Renderer backend used by //donner/svg/renderer:renderer.
# Override with --//donner/svg/renderer:renderer_backend=<tiny_skia|geode>
# or via donner.configure(renderer = "...") in MODULE.bazel.
string_flag(
    name = "renderer_backend",
    build_setting_default = DONNER_CONFIG.get("renderer", "tiny_skia"),
    visibility = ["//visibility:public"],
)

# Enable filter effects (SVG filter primitives: feGaussianBlur, feColorMatrix, etc.).
# Override with --//donner/svg/renderer:filters=true or via donner.configure(filters = True).
bool_flag(
    name = "filters",
    build_setting_default = DONNER_CONFIG.get("filters", True),
    visibility = ["//visibility:public"],
)

# Enable text rendering (stb_truetype, TTF/OTF/WOFF1). On by default.
# Disable with --//donner/svg/renderer:text=false (or --config=no-text), or via
# donner.configure(text = False).
bool_flag(
    name = "text",
    build_setting_default = DONNER_CONFIG.get("text", True),
    visibility = ["//visibility:public"],
)

# Enable full text rendering (requires text). Adds FreeType (hinted outlines),
# HarfBuzz (GSUB/GPOS shaping), and WOFF2 support.
# Override with --//donner/svg/renderer:text_full=true or via donner.configure(text_full = True).
bool_flag(
    name = "text_full",
    build_setting_default = DONNER_CONFIG.get("text_full", False),
    visibility = ["//visibility:public"],
)

# Gate targets that read `@resvg-test-suite` at analysis/runtime.
#
# The upstream repo is fetched only for local development / CI (via the
# non_bcr_deps dev module extension), and is not available when Donner is
# consumed as a dep from BCR. Defaults to False so BCR consumers' broad
# `bazel build @donner//...` cleanly skips those tests instead of failing
# to resolve `@resvg-test-suite`. Donner's own `.bazelrc` sets this to
# True unconditionally so local dev and CI continue to build/run the
# tests exactly as before.
bool_flag(
    name = "resvg_test_suite_available",
    build_setting_default = False,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "renderer_backend_tiny_skia",
    flag_values = {":renderer_backend": "tiny_skia"},
    visibility = ["//visibility:public"],
)

# Geode (WebGPU + Slug) backend selection. Using this backend also requires
# --//donner/svg/renderer/geode:enable_geode=true so that wgpu-native is
# compiled; `--config=geode` in .bazelrc sets both flags together.
config_setting(
    name = "renderer_backend_geode",
    flag_values = {":renderer_backend": "geode"},
    visibility = ["//visibility:public"],
)

config_setting(
    name = "filters_enabled",
    flag_values = {":filters": "true"},
    visibility = ["//visibility:public"],
)

config_setting(
    name = "text_enabled",
    flag_values = {":text": "true"},
    visibility = ["//visibility:public"],
)

config_setting(
    name = "text_full_enabled",
    flag_values = {
        ":text_full": "true",
        ":text": "true",
    },
    visibility = ["//visibility:public"],
)

config_setting(
    name = "macos_coretext",
    constraint_values = ["@platforms//os:macos"],
)

config_setting(
    name = "linux_fontconfig",
    constraint_values = ["@platforms//os:linux"],
)

config_setting(
    name = "resvg_test_suite_enabled",
    flag_values = {":resvg_test_suite_available": "True"},
    visibility = ["//visibility:public"],
)

