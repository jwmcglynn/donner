donner_cc_library(
    name = "renderer_tiny_skia",
    srcs = ["RendererTinySkia.cc"],
    hdrs = ["RendererTinySkia.h"],
    visibility = ["//visibility:public"],
    target_compatible_with = renderer_backend_compatible_with(["tiny_skia"]),
    defines = select({
        ":filters_enabled": ["DONNER_FILTERS_ENABLED"],
        "//conditions:default": [],
    }) + select({
        ":text_enabled": ["DONNER_TEXT_ENABLED"],
        "//conditions:default": [],
    }) + select({
        ":text_full_enabled": ["DONNER_TEXT_FULL"],
        "//conditions:default": [],
    }),
    deps = [
        ":renderer_driver",
        ":renderer_image_io",
        ":renderer_interface",
        ":tiny_skia_deps",
        "//donner/base",
        "//donner/svg",
    ] + select({
        ":filters_enabled": [
            ":filter_graph_executor",
            ":tiny_skia_filter_deps",
        ],
        "//conditions:default": [],
    }) + select({
        ":text_full_enabled": [":text_backend_full"],
        ":text_enabled": [":text_backend_simple"],
        "//conditions:default": [],
    }) + select({
        ":text_enabled": [":text_engine"],
        "//conditions:default": [],
    }),
)

donner_cc_library(
    name = "renderer",
    srcs = [
        "Renderer.cc",
        "RendererInternal.h",
    ] + select({
        ":renderer_backend_tiny_skia": [
            "RendererTinySkiaBackend.cc",
        ],
        "//conditions:default": [
            "RendererSkiaBackend.cc",
        ],
    }),
    hdrs = ["Renderer.h"],
    visibility = ["//visibility:public"],
    deps = [
        ":renderer_driver",
        ":renderer_image_io",
        ":renderer_interface",
    ] + select({
        ":renderer_backend_tiny_skia": [":renderer_tiny_skia"],
        "//conditions:default": [":renderer_skia"],
    }),
)

donner_cc_binary(
    name = "renderer_tool",
    srcs = ["renderer_tool.cc"],
    deps = [
        ":renderer",
        "//donner/base:failure_signal_handler",
        "//donner/svg/parser",
    ],
)
