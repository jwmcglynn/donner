donner_perf_sensitive_cc_library(
    name = "renderer_tiny_skia",
    srcs = ["RendererTinySkia.cc"],
    hdrs = ["RendererTinySkia.h"],
    defines = select({
        ":text_enabled": ["DONNER_TEXT_ENABLED"],
        "//conditions:default": [],
    }) + select({
        ":text_full_enabled": ["DONNER_TEXT_FULL"],
        "//conditions:default": [],
    }) + select({
        ":filters_enabled": ["DONNER_FILTERS_ENABLED"],
        "//conditions:default": [],
    }),
    # The tiny-skia renderer is a pure-CPU library (no wgpu): no
    # `target_compatible_with` so it builds under every config, including geode.
    # The geode-enabled test binary links both backends to run geode-vs-tiny-skia
    # parity in one process (see docs/design_docs/0017-geode_renderer.md §Phase
    # 4b). Production rendering still routes through `:renderer`, which selects
    # exactly one backend per config — so production geode never links this
    # target. That invariant is enforced by
    # //donner/svg/renderer:geode_excludes_tiny_skia_audit.
    visibility = ["//visibility:public"],
    deps = [
        ":pixel_format_utils",
        ":renderer_driver",
        ":renderer_image_io",
        ":renderer_interface",
        ":tiny_skia_deps",
        "//donner/base",
        "//donner/svg",
    ] + select({
        ":text_enabled": [
            ":placed_text_geometry",
            "//donner/svg/text:text_engine",
        ],
        "//conditions:default": [],
    }) + select({
        ":text_enabled": ["//donner/svg/text:text_layout_params"],
        "//conditions:default": [],
    }) + select({
        ":filters_enabled": [
            ":filter_graph_executor",
            ":tiny_skia_filter_deps",
        ],
        "//conditions:default": [],
    }),
)

