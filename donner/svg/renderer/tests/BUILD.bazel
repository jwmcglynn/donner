donner_cc_library(
    name = "renderer_test_backend",
    testonly = 1,
    srcs = select({
        "//donner/svg/renderer:renderer_backend_skia": [
            "RendererTestBackendSkia.cc",
        ],
        "//donner/svg/renderer:renderer_backend_geode": [
            "RendererTestBackendGeode.cc",
        ],
        "//conditions:default": [
            "RendererTestBackendTinySkia.cc",
        ],
    }),
    hdrs = [
        "RendererTestBackend.h",
    ],
    # `DONNER_TEXT_ENABLED` flips the feature bit for
    # `RendererBackendFeature::Text` inside `RendererTestBackendGeode.cc`
    # -- Phase 4 text rendering is compiled into RendererGeode only when
    # the build is configured with `--config=text` / `--config=text-full`,
    # and the feature flag here needs to agree so the resvg test gate
    # doesn't incorrectly skip text tests.
    defines = select({
        "//donner/svg/renderer:text_enabled": ["DONNER_TEXT_ENABLED"],
        "//conditions:default": [],
    }),
    deps = [
        "//donner/svg/renderer",
    ] + select({
        "//donner/svg/renderer:renderer_backend_geode": [
            "//donner/svg/renderer:renderer_geode",
            "//donner/svg/renderer/geode:geode_device",
        ],
        "//conditions:default": [],
    }),
)

