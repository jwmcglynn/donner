donner_cc_library(
    name = "renderer_test_backend",
    testonly = 1,
    # The shared dispatcher (RendererTestBackend.cc) plus the tiny-skia backend
    # TU are always linked; the geode build additionally links the geode
    # backend TU so a single binary can dispatch to *both* renderers at runtime
    # (geode-vs-tiny-skia parity — see docs/design_docs/0017 §Phase 4b). Each
    # backend TU registers its ops into the dispatcher's table.
    srcs = [
        "RendererTestBackend.cc",
        "RendererTestBackendTinySkia.cc",
    ] + select({
        "//donner/svg/renderer:renderer_backend_geode": [
            "RendererTestBackendGeode.cc",
        ],
        "//conditions:default": [],
    }),
    hdrs = [
        "RendererTestBackend.h",
    ],
    # `DONNER_TEXT_ENABLED` flips the feature bit for `RendererBackendFeature::Text`
    # -- Phase 4 text rendering is compiled into the renderers only when the build
    # is configured with `--config=text` / `--config=text-full`, and the feature
    # flag here needs to agree so the resvg test gate doesn't incorrectly skip
    # text tests. `DONNER_GEODE_BACKEND_AVAILABLE` (geode build only) makes the
    # dispatcher link + register the geode backend and report it as the primary
    # backend via `ActiveRendererBackend()`.
    defines = select({
        "//donner/svg/renderer:text_enabled": ["DONNER_TEXT_ENABLED"],
        "//conditions:default": [],
    }) + select({
        "//donner/svg/renderer:renderer_backend_geode": ["DONNER_GEODE_BACKEND_AVAILABLE"],
        "//conditions:default": [],
    }),
    deps = [
        "//donner/svg/renderer",
        # The tiny-skia renderer is linked in every build (pure CPU, no wgpu).
        "//donner/svg/renderer:renderer_tiny_skia",
        "@com_google_gtest//:gtest",
    ] + select({
        "//donner/svg/renderer:renderer_backend_geode": [
            "//donner/svg/renderer:renderer_geode",
            "//donner/svg/renderer/geode:geode_device",
        ],
        "//conditions:default": [],
    }),
)

