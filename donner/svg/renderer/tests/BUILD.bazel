donner_cc_test(
    name = "renderer_driver_tests",
    srcs = [
        "RendererDriver_tests.cc",
    ],
    deps = [
        "//donner/svg/renderer:renderer_driver",
        "//donner/svg/renderer:renderer_utils",
        "//donner/svg/renderer:rendering_context",
        "//donner/svg/tests:parser_test_utils",
        "@com_google_gtest//:gtest_main",
    ],
)

donner_cc_test(
    name = "resvg_test_suite_impl",
    size = "large",
    srcs = [
        "resvg_test_suite.cc",
    ],
    data = [
        "//donner/svg/renderer/testdata",
        "@resvg-test-suite//:fonts",
        "@resvg-test-suite//:images",
        "@resvg-test-suite//:png",
        "@resvg-test-suite//:svg",
    ],
    shard_count = 32,
    size = "large",
    tags = ["manual"],
    deps = [
        ":image_comparison_test_fixture",
        "//donner/base:base_test_utils",
        "@com_google_gtest//:gtest_main",
    ],
)

donner_transitioned_test(
    name = "resvg_test_suite_tiny_skia",
    dep = ":resvg_test_suite_impl",
    renderer_backend = "tiny_skia",
    testonly = 1,
)

donner_transitioned_test(
    name = "resvg_test_suite_skia",
    dep = ":resvg_test_suite_impl",
    renderer_backend = "skia",
    testonly = 1,
)

alias(
    name = "resvg_test_suite",
    actual = ":resvg_test_suite_tiny_skia",
    testonly = 1,
)

donner_cc_test(
    name = "image_comparison_terminal_preview_tests",
    srcs = [
