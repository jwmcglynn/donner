# Transition wrapper: flips renderer_backend=geode + enable_geode=true so this
# target is reachable from `bazel test //...` without --config=geode.
donner_multi_transitioned_test(
    name = "renderer_geode_golden_tests",
    # Software WebGPU (llvmpipe) rendering is slow in fastbuild; the Lion
    # golden alone can exceed 300 s on aarch64 runners. Cap explicitly at
    # 900 s so a driver hang (e.g., Intel Arc + Mesa 25.2.8 Xe-KMD) gets
    # killed in 15 min instead of rolling up to the default 3600 s.
    size = "large",
    timeout = "long",
    testonly = 1,
    dep = ":renderer_geode_golden_tests_impl",
    renderer_backend = "geode",
    # Route the GPU test action to a remote-execution worker advertising a
    # hardware GPU. Ignored for local / non-remote execution.
    exec_properties = {"gpu": "arc"},
)

