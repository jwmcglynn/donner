load(
    "//build_defs:rules.bzl",
    "donner_cc_library",
    "donner_cc_test",
    "donner_transitioned_test",
    "renderer_backend_compatible_with",
)

donner_cc_library(
    name = "renderer_image_test_utils",
    testonly = 1,
    srcs = [
        "RendererImageTestUtils.cc",
    ],
    hdrs = [
        "RendererImageTestUtils.h",
    ],
    visibility = ["//donner/svg:__subpackages__"],
    deps = [
        "@com_google_gtest//:gtest",
        "@stb//:image",
    ],
)

donner_cc_library(
    name = "renderer_test_utils",
    testonly = 1,
    hdrs = [
        "RendererTestUtils.h",
    ],
    visibility = ["//donner/svg:__subpackages__"],
    deps = [
        ":renderer_test_backend",
        "//donner/svg/renderer",
        "//donner/svg/tests:parser_test_utils",
        "@com_google_gtest//:gtest",
    ],
)

donner_cc_library(
    name = "renderer_test_backend",
    testonly = 1,
    srcs = select({
        "//donner/svg/renderer:renderer_backend_skia": [
            "RendererTestBackendSkia.cc",
        ],
        "//conditions:default": [
            "RendererTestBackendTinySkia.cc",
        ],
    }),
    hdrs = [
        "RendererTestBackend.h",
    ],
    deps = [
        "//donner/svg/renderer",
    ],
)

donner_cc_library(
    name = "image_comparison_test_fixture",
    testonly = 1,
    srcs = [
        "ImageComparisonTestFixture.cc",
    ],
    hdrs = [
        "ImageComparisonTestFixture.h",
    ],
    deps = [
        ":renderer_image_test_utils",
        ":renderer_test_backend",
        "//donner/css:core",
        "//donner/svg/components/resources:resource_manager_context",
        "//donner/svg/parser",
        "//donner/svg/renderer",
        "//donner/svg/renderer:renderer_image_io",
        "//donner/svg/renderer:terminal_image_viewer",
        "@com_google_gtest//:gtest",
        "@pixelmatch-cpp17",
    ],
)

donner_cc_test(
    name = "filter_graph_executor_tests",
    srcs = [
        "FilterGraphExecutor_tests.cc",
    ],
    deps = [
        "//donner/svg/renderer:filter_graph_executor",
        "@com_google_gtest//:gtest_main",
    ],
)

donner_cc_test(
    name = "renderer_tests_impl",
    srcs = [
        "RendererAscii_tests.cc",
        "Renderer_tests.cc",
    ],
    data = [
        "//donner/svg/renderer/testdata",
    ],
    tags = ["manual"],
    deps = [
        ":image_comparison_test_fixture",
        ":renderer_test_utils",
        "//donner/svg/parser",
        "//donner/svg/resources:sandboxed_file_resource_loader",
        "@com_google_gtest//:gtest_main",
    ],
)

donner_transitioned_test(
    name = "renderer_tests_tiny_skia",
    dep = ":renderer_tests_impl",
    renderer_backend = "tiny_skia",
    testonly = 1,
)

donner_transitioned_test(
    name = "renderer_tests_skia",
    dep = ":renderer_tests_impl",
    renderer_backend = "skia",
    testonly = 1,
)

alias(
    name = "renderer_tests",
    actual = ":renderer_tests_tiny_skia",
    testonly = 1,
)

donner_cc_test(
    name = "renderer_public_api_tests_impl",
    srcs = [
        "RendererPublicApi_tests.cc",
    ],
    tags = ["manual"],
    deps = [
        "//donner/svg/renderer",
        "@com_google_gtest//:gtest_main",
    ],
)

donner_transitioned_test(
    name = "renderer_public_api_tests_tiny_skia",
    dep = ":renderer_public_api_tests_impl",
    renderer_backend = "tiny_skia",
    testonly = 1,
)

donner_transitioned_test(
    name = "renderer_public_api_tests_skia",
    dep = ":renderer_public_api_tests_impl",
    renderer_backend = "skia",
    testonly = 1,
)

alias(
    name = "renderer_public_api_tests",
    actual = ":renderer_public_api_tests_tiny_skia",
    testonly = 1,
)

donner_cc_test(
    name = "terminal_image_viewer_tests",
    srcs = ["TerminalImageViewer_tests.cc"],
    deps = [
        "//donner/svg/renderer:terminal_image_viewer",
        "@com_google_gtest//:gtest_main",
    ],
