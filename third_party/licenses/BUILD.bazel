"""Third-party license declarations and aggregated NOTICE targets.

Provides one `license()` target per embedded third-party component plus a
`donner_notice_file` target per build variant. The notice targets are what
application authors consume to obtain a legally-sufficient attribution file
they can embed into their binary (e.g. via `cc_embed_data`).

Only dependencies whose upstream BUILD files do not already declare a
`license()` target are redeclared here. `libpng` and `zlib` ship
their own `license()` in their module overlays, so we reference them
directly in the variant lists below.

Keep the variant lists below in sync with
`tools/generate_build_report.py`'s `_DEPENDENCY_VARIANTS`.
"""

load("@rules_license//rules:license.bzl", "license")
load("//build_defs:licenses.bzl", "donner_notice_file", "donner_notice_file_auto")

package(default_visibility = ["//visibility:public"])

exports_files([
    "freetype.LICENSE.txt",
    "imgui.LICENSE.txt",
    "glfw.LICENSE.md",
    "tracy.LICENSE.txt",
    "roboto.LICENSE.txt",
    "fira-code.LICENSE.txt",
])

license(
    name = "entt",
    package_name = "EnTT",
    package_url = "https://github.com/skypjack/entt",
    package_version = "3.16.0",
    license_kinds = ["@rules_license//licenses/spdx:MIT"],
    license_text = "@entt//:LICENSE",
)

license(
    name = "stb",
    package_name = "stb",
    package_url = "https://github.com/nothings/stb",
    license_kinds = ["@rules_license//licenses/spdx:MIT"],
    license_text = "@stb//:LICENSE",
)

license(
    name = "tiny-skia-cpp",
    package_name = "tiny-skia-cpp",
    package_url = "https://github.com/jwmcglynn/tiny-skia-cpp",
    license_kinds = ["@rules_license//licenses/spdx:BSD-3-Clause"],
    license_text = "@tiny-skia-cpp//:LICENSE",
)

# Brotli ships `@brotli//:LICENSE` as an exported source file but no
# `license()` rule, so declare one here.
license(
    name = "brotli",
    package_name = "brotli",
    package_url = "https://github.com/google/brotli",
    license_kinds = ["@rules_license//licenses/spdx:MIT"],
    license_text = "@brotli//:LICENSE",
)

license(
    name = "harfbuzz",
    package_name = "HarfBuzz",
    package_url = "https://github.com/harfbuzz/harfbuzz",
    # HarfBuzz uses the "Old MIT" license; SPDX lists it as MIT with a
    # historical notice.
    license_kinds = ["@rules_license//licenses/spdx:MIT"],
    license_text = "@harfbuzz//:COPYING",
)

license(
    name = "woff2",
    package_name = "woff2",
    package_url = "https://github.com/google/woff2",
    license_kinds = ["@rules_license//licenses/spdx:MIT"],
    license_text = "@woff2//:LICENSE",
)

# FreeType's upstream BUILD.bazel overlay only uses the legacy
# `licenses(["notice"])` declaration and does not export `LICENSE.TXT`, so we
# ship a local copy of FreeType's combined LICENSE.TXT + FTL.TXT text.
license(
    name = "freetype",
    package_name = "FreeType",
    package_url = "https://freetype.org/",
    package_version = "2.13.3",
    license_kinds = ["@rules_license//licenses/spdx:FTL"],
    license_text = "freetype.LICENSE.txt",
)

# Dear ImGui — only consumed under //donner/editor/. Donner pulls imgui via
# `git_override` in MODULE.bazel and the patch we apply does not export
# LICENSE.txt, so we ship a local copy.
license(
    name = "imgui",
    package_name = "Dear ImGui",
    package_url = "https://github.com/ocornut/imgui",
    # Pinned to commit ee1deccc in MODULE.bazel.
    package_version = "ee1deccc",
    license_kinds = ["@rules_license//licenses/spdx:MIT"],
    license_text = "imgui.LICENSE.txt",
)

# GLFW — only consumed under //donner/editor/. Same vendoring story as imgui:
# the donner-supplied BUILD overlay does not export LICENSE.md.
license(
    name = "glfw",
    package_name = "GLFW",
    package_url = "https://www.glfw.org/",
    # Pinned to commit 4df5129 in MODULE.bazel.
    package_version = "4df5129",
    license_kinds = ["@rules_license//licenses/spdx:Zlib"],
    license_text = "glfw.LICENSE.md",
)

# Tracy profiler — only consumed under //donner/editor/. Pulled from upstream
# via the non_bcr_deps extension; we vendor a local copy of LICENSE rather
# than rely on `@tracy//:LICENSE` so the variant build does not depend on the
# external repo being fetched.
license(
    name = "tracy",
    package_name = "Tracy Profiler",
    package_url = "https://github.com/wolfpld/tracy",
    package_version = "v0.12.2",
    license_kinds = ["@rules_license//licenses/spdx:BSD-3-Clause"],
    license_text = "tracy.LICENSE.txt",
)

license(
    name = "emscripten-glfw",
    package_name = "emscripten-glfw",
    package_url = "https://github.com/pongasoft/emscripten-glfw",
    license_kinds = ["@rules_license//licenses/spdx:Apache-2.0"],
    license_text = "//third_party/emscripten-glfw:LICENSE.txt",
)

# Roboto — UI font embedded in //donner/editor. Apache-2.0 per Google Fonts.
license(
    name = "roboto",
    package_name = "Roboto",
    package_url = "https://fonts.google.com/specimen/Roboto",
    license_kinds = ["@rules_license//licenses/spdx:Apache-2.0"],
    license_text = "roboto.LICENSE.txt",
)

# FiraCode — monospace source-pane font embedded in //donner/editor.
# SIL Open Font License 1.1.
license(
    name = "fira-code",
    package_name = "Fira Code",
    package_url = "https://github.com/tonsky/FiraCode",
    license_kinds = ["@rules_license//licenses/spdx:OFL-1.1"],
    license_text = "fira-code.LICENSE.txt",
)

# Canonical per-variant license lists. These match the build-report
# variants in `tools/generate_build_report.py` so a Python script can
# correlate cquery results with the aggregated manifest.

DEFAULT_LICENSES = [
    ":entt",
    ":stb",
    ":tiny-skia-cpp",
    "@libpng//:license",
    "@zlib//:license",
]

TEXT_FULL_LICENSES = DEFAULT_LICENSES + [
    ":brotli",
    ":freetype",
    ":harfbuzz",
    ":woff2",
]

SKIA_TEXT_FULL_LICENSES = []  # Removed: full-Skia backend no longer exists.

ALL_KNOWN_LICENSES = [
    ":entt",
    ":stb",
    ":tiny-skia-cpp",
    ":brotli",
    ":freetype",
    ":harfbuzz",
    ":woff2",
    ":imgui",
    ":glfw",
    ":tracy",
    ":emscripten-glfw",
    ":roboto",
    ":fira-code",
    "@libpng//:license",
    "@zlib//:license",
]

donner_notice_file(
    name = "notice_default",
    variant = "Default (tiny-skia)",
    licenses = DEFAULT_LICENSES,
)

donner_notice_file(
    name = "notice_text_full",
    variant = "tiny-skia + text-full",
    licenses = TEXT_FULL_LICENSES,
)

donner_notice_file_auto(
    name = "notice_editor",
    variant = "editor (auto-detected from current build)",
    target = select({
        "//donner/editor/wasm:wasm_enabled": "//donner/editor/wasm:notice_inputs",
        "//conditions:default": "//donner/editor:editor_notice_inputs",
    }),
    available_licenses = ALL_KNOWN_LICENSES,
)
