+static const char __shader_frag_premultiplied_alpha_wgsl[] = R"(
+struct VertexOutput {
+    @builtin(position) position: vec4<f32>,
+    @location(0) color: vec4<f32>,
+    @location(1) uv: vec2<f32>,
+};
+
+struct Uniforms {
+    mvp: mat4x4<f32>,
+    gamma: f32,
+};
+
+@group(0) @binding(0) var<uniform> uniforms: Uniforms;
+@group(0) @binding(1) var s: sampler;
+@group(1) @binding(0) var t: texture_2d<f32>;
+
+@fragment
+fn main(in: VertexOutput) -> @location(0) vec4<f32> {
+    let tex_color = textureSample(t, s, in.uv);
+    let color = vec4<f32>(
+        tex_color.rgb * in.color.rgb * in.color.a,
+        tex_color.a * in.color.a);
+    let corrected_color = pow(color.rgb, vec3<f32>(uniforms.gamma));
+    return vec4<f32>(corrected_color, color.a);
+}
+)";
+
+static void RemoveStorageKey(ImGuiStorage& storage, ImGuiID key)
+{
+    for (int n = 0; n < storage.Data.Size; n++)
+    {
+        ImGuiStoragePair& pair = storage.Data[n];
+        if (pair.key == key)
+        {
+            storage.Data.erase(&pair);
+            return;
+        }
+    }
+}
+
 static void SafeRelease(ImDrawIdx*& res)
 {
     if (res)
@@ -259,6 +295,7 @@ static void SafeRelease(RenderResources& res)
     SafeRelease(res.Uniforms);
     SafeRelease(res.CommonBindGroup);
     SafeReleaseImageBindGroupCache(res);
+    res.PremultipliedAlphaTextureRefs.Clear();
     SafeRelease(res.ImageBindGroupLayout);
 };

@@ -292,6 +329,57 @@ static WGPUBindGroup ImGui_ImplWGPU_CreateImageBindGroup(WGPUBindGroupLayout la
     return wgpuDeviceCreateBindGroup(bd->wgpuDevice, &image_bg_descriptor);
 }

+static bool ImGui_ImplWGPU_TextureUsesPremultipliedAlpha(ImTextureID texture_id)
+{
+    ImGui_ImplWGPU_Data* bd = ImGui_ImplWGPU_GetBackendData();
+    if (bd == nullptr)
+        return false;
+
+    ImGuiID tex_id_hash = ImHashData(&texture_id, sizeof(texture_id));
+    return bd->renderResources.PremultipliedAlphaTextureRefs.GetInt(tex_id_hash, 0) > 0;
+}
+
+void ImGui_ImplWGPU_SetTexturePremultipliedAlpha(ImTextureID texture_id, bool premultiplied_alpha)
+{
+    ImGui_ImplWGPU_Data* bd = ImGui_ImplWGPU_GetBackendData();
+    if (bd == nullptr || texture_id == 0)
+        return;
+
+    ImGuiID tex_id_hash = ImHashData(&texture_id, sizeof(texture_id));
+    if (premultiplied_alpha)
+    {
+        if (bd->renderResources.PremultipliedAlphaTextureRefs.GetInt(tex_id_hash, 0) <= 0)
+            bd->renderResources.PremultipliedAlphaTextureRefs.SetInt(tex_id_hash, 1);
+    }
+    else
+        RemoveStorageKey(bd->renderResources.PremultipliedAlphaTextureRefs, tex_id_hash);
+}
+
+void ImGui_ImplWGPU_AddTexturePremultipliedAlphaRef(ImTextureID texture_id)
+{
+    ImGui_ImplWGPU_Data* bd = ImGui_ImplWGPU_GetBackendData();
+    if (bd == nullptr || texture_id == 0)
+        return;
+
+    ImGuiID tex_id_hash = ImHashData(&texture_id, sizeof(texture_id));
+    const int ref_count = bd->renderResources.PremultipliedAlphaTextureRefs.GetInt(tex_id_hash, 0);
+    bd->renderResources.PremultipliedAlphaTextureRefs.SetInt(tex_id_hash, ref_count + 1);
+}
+
+void ImGui_ImplWGPU_RemoveTexturePremultipliedAlphaRef(ImTextureID texture_id)
+{
+    ImGui_ImplWGPU_Data* bd = ImGui_ImplWGPU_GetBackendData();
+    if (bd == nullptr || texture_id == 0)
+        return;
+
+    ImGuiID tex_id_hash = ImHashData(&texture_id, sizeof(texture_id));
+    const int ref_count = bd->renderResources.PremultipliedAlphaTextureRefs.GetInt(tex_id_hash, 0);
+    if (ref_count <= 1)
+        RemoveStorageKey(bd->renderResources.PremultipliedAlphaTextureRefs, tex_id_hash);
+    else
+        bd->renderResources.PremultipliedAlphaTextureRefs.SetInt(tex_id_hash, ref_count - 1);
+}
+
 void ImGui_ImplWGPU_RemoveTexture(ImTextureID texture_id)
 {
     ImGui_ImplWGPU_Data* bd = ImGui_ImplWGPU_GetBackendData();
@@ -313,8 +396,8 @@ void ImGui_ImplWGPU_RemoveTexture(ImTextureID texture_id)
         if (bind_group == bd->renderResources.ImageBindGroup)
