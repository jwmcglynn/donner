 IMGUI_IMPL_API void ImGui_ImplWGPU_RemoveTexture(ImTextureID texture_id);
+IMGUI_IMPL_API void ImGui_ImplWGPU_SetTexturePremultipliedAlpha(ImTextureID texture_id, bool premultiplied_alpha);
+IMGUI_IMPL_API void ImGui_ImplWGPU_AddTexturePremultipliedAlphaRef(ImTextureID texture_id);
+IMGUI_IMPL_API void ImGui_ImplWGPU_RemoveTexturePremultipliedAlphaRef(ImTextureID texture_id);

 // Use if you want to reset your rendering device without losing Dear ImGui state.
 IMGUI_IMPL_API void ImGui_ImplWGPU_InvalidateDeviceObjects();
