Subject: [PATCH] Add bazel build files
Base-commit: 126569ad5b3a2c5329cc8ee914dd5b2075f4dd50

---
 BUILD.bazel                  | 90 +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
 backends/imgui_impl_wgpu.cpp |  4 +-
 MODULE.bazel                 | 15 +++++++++++
 3 files changed, 107 insertions(+), 2 deletions(-)
 create mode 100644 BUILD.bazel
 create mode 100644 MODULE.bazel

diff --git a/BUILD.bazel b/BUILD.bazel
new file mode 100644
index 00000000..12345678
--- /dev/null
+++ b/BUILD.bazel
@@ -0,0 +1,90 @@
+""" Builds imgui.
+"""
+
+load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library")
+load("@bazel_skylib//lib:selects.bzl", "selects")
+
+package(default_visibility = ["//visibility:public"])
+
+cc_library(
+    name = "imgui",
+    srcs = [
+        "backends/imgui_impl_glfw.cpp",
+        "backends/imgui_impl_opengl3.cpp",
+        "imconfig.h",
+        "imgui.cpp",
+        "imgui_draw.cpp",
+        "imgui_tables.cpp",
+        "imgui_widgets.cpp",
+        "imstb_rectpack.h",
+        "imstb_textedit.h",
+        "imstb_truetype.h",
+        "misc/cpp/imgui_stdlib.cpp",
+    ],
+    hdrs = [
+        "backends/imgui_impl_glfw.h",
+        "backends/imgui_impl_opengl3.h",
+        "backends/imgui_impl_opengl3_loader.h",
+        "imgui.h",
+        "imgui_internal.h",
+        "misc/cpp/imgui_stdlib.h",
+    ],
+    copts = [
+        "-Wno-nontrivial-memcall",
+        "-Wno-uninitialized-const-pointer",
+    ] + selects.with_or({
+        ("@platforms//cpu:wasm32", "@platforms//cpu:wasm64"): [],
+        "//conditions:default": [
+            "-DIMGUI_IMPL_OPENGL_LOADER_CUSTOM",
+            "-include",
+            "glad/glad.h",
+        ],
+    }),
+    defines = ["IMGUI_ENABLE_OSX_DEFAULT_CLIPBOARD_FUNCTIONS"],
+    includes = ["backends"],
+    visibility = ["//visibility:public"],
+    deps = [
+        "@glfw",
+    ] + selects.with_or({
+        ("@platforms//cpu:wasm32", "@platforms//cpu:wasm64"): [],
+        "//conditions:default": [
+            "@donner//third_party/glad",
+        ],
+    }),
+)
+
+cc_library(
+    name = "imgui_wgpu_backend",
+    srcs = [
+        "backends/imgui_impl_wgpu.cpp",
+    ],
+    hdrs = [
+        "backends/imgui_impl_wgpu.h",
+    ],
+    copts = [
+        "-Wno-nontrivial-memcall",
+        "-Wno-uninitialized-const-pointer",
+    ],
+    defines = ["IMGUI_IMPL_WEBGPU_BACKEND_DAWN"],
+    includes = ["backends"],
+    visibility = ["//visibility:public"],
+    deps = [
+        ":imgui",
+        "@donner//third_party/webgpu-cpp:webgpu_cpp",
+    ],
+)
+
+cc_binary(
+    name = "imgui_demo",
+    srcs = [
+        "imgui_demo.cpp",
+        "examples/example_glfw_opengl3/main.cpp",
+    ],
+    linkopts = ["-framework", "OpenGL", "-framework", "Cocoa", "-framework", "IOKit", "-framework", "CoreVideo"],
+    visibility = ["//visibility:public"],
+    deps = [
+        ":imgui",
+        "@donner//third_party/glad",
+        "@glfw",
+    ],
+)
diff --git a/backends/imgui_impl_wgpu.cpp b/backends/imgui_impl_wgpu.cpp
index 12345678..23456789 100644
--- a/backends/imgui_impl_wgpu.cpp
+++ b/backends/imgui_impl_wgpu.cpp
@@ -564,12 +564,12 @@ static void ImGui_ImplWGPU_CreateFontsTexture()
     // Upload texture data
     {
-        WGPUImageCopyTexture dst_view = {};
+        WGPUTexelCopyTextureInfo dst_view = {};
         dst_view.texture = bd->renderResources.FontTexture;
         dst_view.mipLevel = 0;
         dst_view.origin = { 0, 0, 0 };
         dst_view.aspect = WGPUTextureAspect_All;
-        WGPUTextureDataLayout layout = {};
+        WGPUTexelCopyBufferLayout layout = {};
         layout.offset = 0;
         layout.bytesPerRow = width * size_pp;
         layout.rowsPerImage = height;
         WGPUExtent3D size = { (uint32_t)width, (uint32_t)height, 1 };
diff --git a/MODULE.bazel b/MODULE.bazel
new file mode 100644
index 00000000..4c85d76a
--- /dev/null
+++ b/MODULE.bazel
@@ -0,0 +1,15 @@
+module(
+    name = "imgui",
+    version = "0.0.0",
+)
+
+bazel_dep(name = "rules_cc", version = "0.0.9")
+bazel_dep(name = "platforms", version = "0.0.10")
+bazel_dep(name = "bazel_skylib", version = "1.7.1")
+bazel_dep(name = "glfw", version = "0.0.0")
+
+bazel_dep(name = "donner", version = "0.0.0")
+local_path_override(
+    module_name = "donner",
+    path = "..",
+)
--
