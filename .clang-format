---
BasedOnStyle: Google
AccessModifierOffset: -2
# Standalone `{ stmt; }` scope blocks stay on one line. clang-format 18
# and 19 disagree on the default `Never` here — 18 keeps such blocks
# inline regardless, 19 reflows them. `Empty` is the smallest setting
# that makes both versions agree on standalone scope blocks while
# keeping `if (x) { return; }` / `while (y) { step(); }` reflowed
# across multiple lines, matching prior project style.
AllowShortBlocksOnASingleLine: Empty
AllowShortCaseLabelsOnASingleLine: true
AllowShortFunctionsOnASingleLine: Inline
ColumnLimit: 100
IndentWidth: 2
---
Language: Cpp
# Force pointers to the type for C++.
DerivePointerAlignment: false
PointerAlignment: Left

IncludeIsMainRegex: '(_tests?)?$'

#
# Disable formatting for comments containing these conditions:
#
# '|' - For Doxygen comments containing markdown tables
# 'NOLINT' - For linter suppressions
# '>' - For markdown blockquotes
# ' *<' - For embedded XML, a '<' with optional spaces before it (e.g. '<svg>...')
CommentPragmas: '^(\||NOLINT|\>| *<)'
