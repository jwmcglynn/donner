bazel_dep(name = "imgui", version = "0.0.0", dev_dependency = True)
git_override(
    module_name = "imgui",
    commit = "ee1deccc08c14ab1e6abcfa6aae11d915763cdb7",
    patch_strip = 1,
    patches = [
        "//third_party/patches:imgui_bazel_build_files.patch",
        "//third_party/patches:imgui_wgpu_texture_cache.patch",
        "//third_party/patches:imgui_wgpu_premultiplied_textures.patch",
        "//third_party/patches:imgui_wgpu_emscripten_dawn.patch",
        "//third_party/patches:imgui-explicit-raw-memory.patch",
    ],
    remote = "https://github.com/ocornut/imgui",
