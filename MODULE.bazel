bazel_dep(name = "glfw", version = "0.0.0", dev_dependency = True)
git_override(
    module_name = "glfw",
    commit = "ed6452b13c76f7b4da216a9952bc7837aeb0f031",
    patch_strip = 1,
    patches = [
        "//third_party/patches:glfw_bazel_build_files.patch",
    ],
    remote = "https://github.com/glfw/glfw",
)
