{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://donner.graphics/svg2-suite/baseline-lock-v1.schema.json",
  "title": "Donner SVG2 Suite baseline lock, version 1",
  "description": "Pins the exact SVG 2 formal publication and editorial-delta source revisions with content digests, plus the normative dependency lock. The offline runner consumes only this lock; a separate reviewed updater changes it.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "formal_baseline", "editorial_delta_baseline", "dependency_lock"],
  "properties": {
    "schema": {
      "const": "https://donner.graphics/svg2-suite/baseline-lock-v1.schema.json"
    },
    "formal_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specification", "url", "publication_date", "status", "stable", "content_digest"],
      "properties": {
        "specification": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "pattern": "^https://"
        },
        "publication_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "stable": {
          "type": "boolean"
        },
        "content_digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "editorial_delta_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "revision", "retrieved", "advisory"],
      "properties": {
        "source": {
          "type": "string",
          "pattern": "^https://"
        },
        "revision": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "retrieved": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "advisory": {
          "type": "boolean"
        }
      }
    },
    "dependency_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependency"
          }
        }
      }
    }
  },
  "$defs": {
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title", "organization", "url", "status", "stable", "used_by"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "organization": {
          "enum": ["w3c", "whatwg", "ietf", "ecma", "iso", "iec", "unicode", "other"]
        },
        "url": {
          "type": "string",
          "pattern": "^https://"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "edition": {
          "type": "string"
        },
        "revision": {
          "type": "string"
        },
        "successor": {
          "type": "string"
        },
        "stable": {
          "type": "boolean"
        },
        "used_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
