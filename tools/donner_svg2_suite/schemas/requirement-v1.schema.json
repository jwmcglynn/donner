{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://donner.graphics/svg2-suite/requirement-v1.schema.json",
  "title": "Donner SVG2 Suite normative requirement inventory, version 1",
  "description": "Reviewed SVG 2 normative requirements. The inventory is the source of truth for compliance: imported tests link to requirement ids and missing requirements stay visible as gaps. Only 'covered-pass' evidence counts as passing compliance.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "baseline", "requirements"],
  "properties": {
    "schema": {
      "const": "https://donner.graphics/svg2-suite/requirement-v1.schema.json"
    },
    "baseline": {
      "type": "string",
      "minLength": 1,
      "description": "Formal SVG 2 baseline identifier this inventory audits, for example 'svg2-cr-20181004'."
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requirement"
      }
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "spec_revision",
        "section",
        "anchor",
        "assertion",
        "strength",
        "subject",
        "software_classes",
        "processing_modes",
        "oracle_kinds",
        "review_state",
        "evidence_state",
        "source_text_hash"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^svg2-cr-20181004/[a-z0-9-]+/[A-Za-z0-9._-]+/req-[0-9]{2,}$",
          "description": "Stable id: locked spec id, chapter, section anchor, and reviewed ordinal. Contains no prose hash so wording edits do not churn ids."
        },
        "spec_revision": {
          "type": "string",
          "minLength": 1
        },
        "section": {
          "type": "string",
          "minLength": 1
        },
        "anchor": {
          "type": "string",
          "minLength": 1
        },
        "assertion": {
          "type": "string",
          "minLength": 1,
          "description": "Short paraphrased normative assertion."
        },
        "strength": {
          "enum": ["must", "must-not", "should", "should-not", "may", "required", "recommended", "optional"]
        },
        "subject": {
          "enum": [
            "user-agent",
            "viewer",
            "high-quality-viewer",
            "interpreter",
            "author",
            "generator",
            "authoring-tool",
            "server"
          ]
        },
        "software_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["generator", "authoring-tool", "server", "interpreter", "viewer", "high-quality-viewer"]
          }
        },
        "processing_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["dynamic-interactive", "animated", "secure-animated", "static", "secure-static"]
          }
        },
        "feature_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "security_mode": {
          "type": "string"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Requirement ids or dependency-lock keys this requirement's behavior depends on."
        },
        "oracle_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "png",
              "parse",
              "dom",
              "computed-style",
              "accessibility",
              "resource-trace",
              "event-trace",
              "animation-sample",
              "manual"
            ]
          }
        },
        "test_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_state": {
          "enum": ["unreviewed", "reviewed"]
        },
        "evidence_state": {
          "enum": [
            "covered-pass",
            "covered-fail",
            "missing-test",
            "unsupported",
            "not-applicable",
            "not-directly-testable",
            "spec-ambiguity",
            "draft-dependency"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_text_hash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
